{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext", // Asegúrate de que esta línea esté presente
    "target": "esnext",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,      // Permite importar paquetes CommonJS como Express
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}